  color: var(--color-text-primary);
}

/* ─── Matrix Background ─────────────────────────────────────── */
.matrix-bg {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.matrix-bg::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    repeating-linear-gradient(
      0deg,
      transparent,
      transparent 24px,
      var(--color-matrix-grid) 24px,
      var(--color-matrix-grid) 25px
    ),
    repeating-linear-gradient(
      90deg,
      transparent,
      transparent 24px,
      var(--color-matrix-grid) 24px,
      var(--color-matrix-grid) 25px
    );
  background-size: 25px 25px;
  opacity: 0.6;
}

.matrix-bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to bottom,
    transparent 0%,
    var(--color-matrix-stream-bright) 10%,
    transparent 100%
  );
  background-size: 100% 200%;
  animation: scanline 8s linear infinite;
  opacity: 0.5;
