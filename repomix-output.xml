.bg-risk-high { background-color: var(--color-risk-high-bg); }
.bg-risk-critical { background-color: var(--color-risk-critical-bg); }

/* ─── Status Dot ─────────────────────────────────────────────── */
.status-dot {
  display: inline-block;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background-color: var(--color-accent-primary);
  animation: pulse-glow 2s ease-in-out infinite;
}

/* ─── Intelligence Card ──────────────────────────────────────── */
.intel-card {
  background-color: var(--color-bg-surface);
  border: 1px solid var(--color-border);
  border-radius: 8px;
  transition: border-color 200ms ease, box-shadow 200ms ease;
}

.intel-card:hover {
  border-color: rgba(0, 245, 102, 0.2);
}

.light .intel-card:hover {
  border-color: rgba(26, 122, 60, 0.2);
}

/* ─── Keyframe Animations ────────────────────────────────────── */
@keyframes pulse-glow {
  0%, 100% { opacity: 0.5; }
  50% { opacity: 1; }
}

@keyframes scanline {
  0% { background-position: 0 -100vh; }
  100% { background-position: 0 100vh; }
}

@keyframes ping-slow {
  0% { transform: scale(1); opacity: 0.8; }
  80%, 100% { transform: scale(2); opacity: 0; }
}

@keyframes fade-in-up {
  from { opacity: 0; transform: translateY(8px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slide-in-right {
  from { opacity: 0; transform: translateX(16px); }
  to { opacity: 1; transform: translateX(0); }
}

.animate-fade-in-up { animation: fade-in-up 300ms ease forwards; }
